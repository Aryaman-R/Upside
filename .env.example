# Upside — environment variables (Vite exposes only VITE_-prefixed vars).
#
# Cloud sync (Phase 1: auth + multi-device state sync) is OPTIONAL. With these
# unset, the app runs exactly as before: fully local, offline, no account.
# Set them to your Supabase project's values to enable accounts + sync.
#
# Copy this file to `.env.local` (gitignored) and fill in real values.

VITE_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key
